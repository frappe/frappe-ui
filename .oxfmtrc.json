{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "semi": false,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 80,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "quoteProps": "consistent",
  "objectWrap": "preserve",
  "proseWrap": "preserve",
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "auto-imports.d.ts",
    "components.d.ts",
    ".nyc_output/**",
    "coverage/**"
  ]
}
