{
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/index.ts",
    "frappe/**/*.ts",
    "frappe/**/*.d.ts",
    "frappe/**/*.tsx",
    "frappe/**/*.vue",
    "frappe/index.js",
    "frappe/index.d.ts"
  ],
  "exclude": ["src/**/*.cy.ts", "frappe/**/*.cy.ts", "src/mocks/**/*"],
  "extends": "./tsconfig.base.json",
  "references": [{ "path": "./tsconfig.node.json" }],
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@molecules/*": ["src/molecules/*"],
      "@utils/*": ["src/utils/*"],
      "@composables/*": ["src/composables/*"]
    }
  }
}
